# CogniLink Environment Variables
# These are used by LangChain provider packages (not by CogniLink directly).
# Set the ones relevant to your chosen LLM provider.

# OpenAI (for langchain-openai)
OPENAI_API_KEY=sk-your-key-here

# Anthropic (for langchain-anthropic)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# AWS Bedrock (for langchain-aws)
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_DEFAULT_REGION=us-east-1

# Ollama (for langchain-ollama) — no API key needed, just the base URL
# OLLAMA_BASE_URL=http://localhost:11434
